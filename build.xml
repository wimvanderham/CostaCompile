      </propath>
    </PCTCompile>
    <antcall target="cp_rcode_API" />
  </target>

  <target name="cp_rcode_API" description="Copia i compilati delle API dalla cartella rcodeAPI.pct nella cartella dei sorgenti">
    <copy todir="/appl/${env.AMBIENTE}/">
      <fileset dir="/appl/${env.AMBIENTE}/rcodeAPI.pct">
        <include name="aoa/**/*.r" />
      </fileset>
    </copy>
  </target>
  

  <target name="cp_r_code" description="Copia r code in cartella principale">
    <copy todir="/appl/${env.AMBIENTE}/rcode" flatten="true">
      <fileset dir="/appl/${env.AMBIENTE}/rcode">
         <include name="**/*r" />
         <exclude name="aoa/"/>
      </fileset>
    </copy>
    <copy todir="/appl/${env.AMBIENTE}/">
      <fileset dir="/appl/${env.AMBIENTE}/rcode">
              <include name="aoa/**/*.r" />
      </fileset>
    </copy>
  </target>

  <target name="cp_r_code_no_aoa" description="Copia r code in cartella principale, tranne aoa">
    <copy todir="/appl/${env.AMBIENTE}/rcode" flatten="true">
      <fileset dir="/appl/${env.AMBIENTE}/rcode">
         <include name="**/*r" />
         <exclude name="aoa/"/>
      </fileset>
    </copy>
  </target>


  <target name="compsy" description="Compilazione dei sorgenti nella cartella /appl/costaprd/sy">
    <PCTCompile graphicalMode="False" destDir="/appl/costaprd/rcode.pct/" displayFiles="1" dlcHome="${env.DLC}">
      <fileset dir="/appl/costaprd/" includes="sy/**/*.p" />
      <propath>
        <pathelement path="/appl/costaprd"/>
      </propath>
    </PCTCompile>
    <copy todir="/appl/costaprd/">
      <fileset dir="/appl/costaprd/rcode.pct">
              <include name="sy/**/*.r" />
      </fileset>

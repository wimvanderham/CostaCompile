<?xml version="1.0" encoding="utf-8"?>
<project name="Compilazione TTG in Cloud">
  <property environment="env" />
  <property name="pct.home" value="${env.PCT_HOME}"/>

  <taskdef resource="PCT.properties" classpath="${pct.home}/PCT.jar"/>
  <typedef resource="types.properties" classpath="${pct.home}/PCT.jar"/>

  <target name="check_env" description="Verifica le variabili d'ambiente richieste">
    <condition property="env.missing">
      <or>
        <not><isset property="env.AMBIENTE"/></not>
        <not><isset property="env.DB_PORT"/></not>
        <not><isset property="env.DLC"/></not>
        <not><isset property="env.PCT_HOME"/></not>
      </or>
    </condition>
    <fail if="env.missing" message="Variabili d'ambiente mancanti. Assicurati che AMBIENTE, DB_PORT, DLC e PCT_HOME siano valorizzate."/>
  </target>

  <target name="creDB" description="Create DB TTG from file .df">
    <PCTCreateDatabase dbName="ttgres" destDir="db" schemaFile="db/ttgres.df" dlcHome="${env.DLC}" />
  </target>

  <target name="compAPI" depends="check_env" description="Compilazione delle API con i sorgenti nella cartella /appl/${env.AMBIENTE}/aoa">
    <PCTCompile graphicalMode="False" destDir="/appl/${env.AMBIENTE}/rcodeAPI.pct/" displayFiles="1" dlcHome="${env.DLC}">
      <fileset dir="/appl/${env.AMBIENTE}/" includes="aoa/**/*.p, aoa/**/*.w, aoa/**/*.cls" />
      <DBConnection dbName="/db/${env.AMBIENTE}/ttgres" hostName="localhost" dbPort="${env.DB_PORT}" userName="compile" password="compile" singleUser="False" />
      <propath>
        <pathelement path="/appl/${env.AMBIENTE}/rcode"/>
        <pathelement path="/appl/${env.AMBIENTE}"/>
        <pathelement path="/appl/${env.AMBIENTE}/sub"/>
